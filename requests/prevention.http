@baseURL=http://127.0.0.1:8443/prevention
#@baseURL=http://app.tecnoelectronics.com.ve:8443/prevention

### GET COMMISSIONS
GET {{baseURL}}/commission

### GET OFFICIALS
GET {{baseURL}}/official

### CREATE COMMISSION

POST {{baseURL}}/commission
Content-Type: application/json

{
  "commission": {
    "brigade_id": 1,
    "authorized_official_id": 1,
    "observations": "Routine inspection"
  },
  "reason": {
    "name": "Annual Review",
    "description": "Standard annual safety inspection",
    "zone": "North Zone",
    "parish_id": 1,
    "municipality_id": 1
  },
  "officials": [
    { "official_id": 1 }
  ],
  "transports": [
    { "transport_id": 4 }
  ]
}

### UPDATE COMMISSION EXIT
POST {{baseURL}}/commission/5/exit
Content-Type: application/json

{
  "observations": "Routine inspection completed",
  "exit_at": "2023-10-01T12:00:00Z",
  "seclusions": [
   { "ci": "V3308169", "last_name": "Doe", "first_name": "John", "status_id": 1 }
  ],
  "transports": [
{
  "type_id": 1,
  "details": "This is a sample transport detail",
  "brand_id": 1,
  "model_id": 1,
  "plate": "ABC-1234333",
  "unit": "Unit-01",
  "status_id": 1
}
  ]
}

### GET COMMISSIONS
GET {{baseURL}}/commission/5/status
Content-Type: application/json

### UPDATE COMMISSION STATUS
PATCH {{baseURL}}/commission/5/status
Content-Type: application/json

{
  "status_at": "2023-10-01T13:00:00Z",
  "seclusions": [
    {
      "id": 1,
      "status_id": 2
    }
  ],
  "transports": [
    {
      "id": 3,
      "status_id": 1
    }
  ]
}


### CREATE OFFICIAL
POST {{baseURL}}/official
Content-Type: application/json

{
  "ci": "33071696",
  "last_name": "Avila",
  "first_name": "Aaron",
  "phone": "555-1234",
  "charge_id": 1,
  "hierarchy_id": 1,
  "brigade_id": 1
}

### GET TRANSPORT
GET {{baseURL}}/transport

### CREATE TRANSPORT
POST {{baseURL}}/transport
Content-Type: application/json

{
  "type_id": 1,
  "details": "This is a sample transport detail",
  "brand_id": 1,
  "model_id": 1,
  "plate": "ABC-12343",
  "unit": "Unit-01",
  "status_id": 1
}

### GET SECLUSIONS
GET {{baseURL}}/seclusion?page=2&limit=1

### GET SECLUSIONS WITH SEARCH
GET {{baseURL}}/seclusion?search=Smith

### CREATE SECLUSION
POST {{baseURL}}/seclusion
Content-Type: application/json

{
  "photo": "base64_encoded_photo_data_here",
  "ci": "V12345678",
  "birthdate": "1990-05-15",
  "age": 33,
  "last_name": "Smith",
  "first_name": "John",
  "reason": "Suspicious activity reported",
  "exit_reason": "",
  "physical_state": "Good health, no visible injuries",
  "outfit": "Blue jeans, white t-shirt, black sneakers",
  "belongings": "Wallet, phone, keys",
  "observations": "Cooperative during initial processing"
}

### GET SECLUSION BY ID
GET {{baseURL}}/seclusion/2

### UPDATE SECLUSION EXIT
PATCH {{baseURL}}/seclusion/1
Content-Type: application/json

{
  "exit_at": "2024-01-15",
  "observations": "Released after investigation completed. No charges filed."
}

### ADD VISIT TO SECLUSION
POST {{baseURL}}/seclusion/1/visit
Content-Type: application/json

{
  "ci": "V87654321",
  "last_name": "Smith",
  "first_name": "Jane",
  "relationship_id": 2,
  "phone": "555-0123",
  "date": "2024-01-10",
  "address": "2024-01-10",
  "reason": "2024-01-10"
}

### GET PARTS
GET {{baseURL}}/part

### CREATE PART
POST {{baseURL}}/part
Content-Type: application/json

{
  "part": {
    "date": "2024-01-15"
  },
  "officials": [
    {
      "official_id": 1,
      "type": "coordinator"
    },
    {
      "official_id": 1,
      "type": "assistant"
    }
  ],
  "developments": [
    {
      "data": {
        "description": "Initial part development",
        "findings": "All systems operational",
        "recommendations": "Continue monitoring"
      },
      "date": "2024-01-15",
      "type_id": 1
    }
  ],
  "responsability": {
    "official_service_ci": "33071696",
    "official_receive_ci": "33071696",
    "official_block_ci": "33071696",
    "official_writer_ci": "33071696",
    "official_deliver_ci": "33071696",
    "official_receive_custody_ci": "33071696",
    "official_hr_ci": "33071696",
    "official_supervisor_ci": "33071696",
    "official_director_ci": "33071696",
    "official_dae_ci": "33071696",
    "official_die_ci": "33071696"
  }
}

### GET PART BY ID
GET {{baseURL}}/part/4

### UPDATE PART COMPLETE
PATCH {{baseURL}}/part/4
Content-Type: application/json

{
  "date": "2024-01-16",
  "responsabilities": 
    {
      "id": 4,
    "official_service_ci": "33071696",
    "official_receive_ci": "33071696",
    "official_block_ci": "33071696",
    "official_writer_ci": "33071696",
    "official_deliver_ci": "33071696",
    "official_receive_custody_ci": "33071696",
    "official_hr_ci": "33071696",
    "official_supervisor_ci": "33071696",
    "official_director_ci": "33071696",
    "official_dae_ci": "33071696",
    "official_die_ci": "33071696"
    },
  "developments": [
    {
      "id": 3,
      "data": {
        "description": "Updated part development",
        "findings": "Minor issues detected",
        "recommendations": "Schedule maintenance"
      },
      "date": "2024-01-16",
      "type_id": 1
    }
  ]
}
