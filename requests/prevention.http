@baseURL=http://127.0.0.1:8443/prevention
#@baseURL=http://app.tecnoelectronics.com.ve:8443/prevention

### GET COMMISSIONS
GET {{baseURL}}/commission

### GET OFFICIALS 
GET {{baseURL}}/official

### CREATE COMMISSION

POST {{baseURL}}/commission
Content-Type: application/json

{
  "commission": {
    "brigade_id": 1,
    "authorized_official_id": 1,
    "observations": "Routine inspection"
  },
  "reason": {
    "name": "Annual Review",
    "description": "Standard annual safety inspection",
    "zone": "North Zone",
    "municipality_id": 1
  },
  "officials": [
    { "official_id": 1 }
  ],
  "transports": [
    { "transport_id": 3 }
  ]
}

### UPDATE COMMISSION EXIT
POST {{baseURL}}/commission/5/exit
Content-Type: application/json

{
  "observations": "Routine inspection completed",
  "exit_at": "2023-10-01T12:00:00Z",
  "seclusions": [
   { "ci": "V3308169", "last_name": "Doe", "first_name": "John", "status_id": 1 }
  ],
  "transports": [
{
  "type_id": 1,
  "details": "This is a sample transport detail",
  "brand_id": 1,
  "model_id": 4,
  "plate": "ABC-123433",
  "unit": "Unit-01",
  "status_id": 1
}
  ]
}

### GET COMMISSIONS
GET {{baseURL}}/commission/5/status
Content-Type: application/json

### UPDATE COMMISSION STATUS
PATCH {{baseURL}}/commission/5/status
Content-Type: application/json

{
  "status_at": "2023-10-01T13:00:00Z",
  "seclusions": [
    {
      "id": 1,
      "status_id": 2
    }
  ],
  "transports": [
    {
      "id": 3,
      "status_id": 1
    }
  ]
}


### CREATE OFFICIAL
POST {{baseURL}}/official
Content-Type: application/json

{
  "ci": "12345678",
  "last_name": "Doe",
  "first_name": "John",
  "phone": "555-1234",
  "charge_id": 1,
  "hierarchy_id": 1,
  "brigade_id": 1
}

### GET TRANSPORT
GET {{baseURL}}/transport

### CREATE TRANSPORT
POST {{baseURL}}/transport
Content-Type: application/json

{
  "type_id": 1,
  "details": "This is a sample transport detail",
  "brand_id": 1,
  "model_id": 4,
  "plate": "ABC-12343",
  "unit": "Unit-01",
  "status_id": 1
}

### GET SECLUSIONS
GET {{baseURL}}/seclusion

### GET SECLUSIONS WITH SEARCH
GET {{baseURL}}/seclusion?search=Smith

### CREATE SECLUSION
POST {{baseURL}}/seclusion
Content-Type: application/json

{
  "photo": "base64_encoded_photo_data_here",
  "ci": "V12345678",
  "birthdate": "1990-05-15",
  "age": 33,
  "last_name": "Smith",
  "first_name": "John",
  "reason": "Suspicious activity reported",
  "exit_reason": "",
  "physical_state": "Good health, no visible injuries",
  "outfit": "Blue jeans, white t-shirt, black sneakers",
  "belongings": "Wallet, phone, keys",
  "observations": "Cooperative during initial processing"
}

### GET SECLUSION BY ID
GET {{baseURL}}/seclusion/1

### UPDATE SECLUSION EXIT
PATCH {{baseURL}}/seclusion/1
Content-Type: application/json

{
  "exit_at": "2024-01-15",
  "observations": "Released after investigation completed. No charges filed."
}

### ADD VISIT TO SECLUSION
POST {{baseURL}}/seclusion/1/visit
Content-Type: application/json

{
  "ci": "V87654321",
  "last_name": "Smith",
  "first_name": "Jane",
  "relationship_id": 2,
  "phone": "555-0123",
  "date": "2024-01-10",
  "address": "2024-01-10",
  "reason": "2024-01-10"
}
